{
    "version": 2,
    "functions": {
        "api/index.php": { "runtime": "vercel-php@0.7.1" }
    },
    "routes": [
        { "src": "/build/(.*)", "dest": "/public/build/$1" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],
    "outputDirectory": "public",
    "installCommand": "echo 'Skipping install commands'",
    "buildCommand": "echo 'Skipping build commands'"
}